.claude/settings.local.json

# Local AI tool state (machine-specific)
.omc/

# Generated artifacts (local only)
.code-graph/
**/node_modules/

# Machine-specific project registry and sync log (each user has their own)
projects.json
.github/sync.log

# OpenSpec change archives (optional — uncomment to ignore)
# openspec/changes/archive/
